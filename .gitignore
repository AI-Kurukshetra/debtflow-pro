# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env (do not commit secrets; add .env.example to repo if you want a template)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / editor
.idea
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.marscode

# OS
Thumbs.db
*.swp
*.swo
*~

# Supabase (local CLI state; keep supabase/migrations in repo)
supabase/.branches
supabase/.temp
supabase/.env
supabase/.env.local
